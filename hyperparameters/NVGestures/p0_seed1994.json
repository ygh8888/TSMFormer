{
    "name": "CMAF Gesture Recognition",
    "dataset": "NVGestures",
    "epochs": 20,
    "data": {
        "data_path": "/data/NVGesture",
        "n_classes": 25,
        "n_frames": 40,
        "batch_size": 8
    },
    "checkpoints": {
        "save_name": "p0_seed1994_nvgestures",
        "save_dir": "./experiments/BL4_p0_multiseed/seed1994/checkpoints/",
        "tb_path": "./experiments/BL4_p0_multiseed/seed1994/train_log"
    },
    "solver": {
        "base_lr": 0.0001,
        "weight_decay": 0.05,
        "decay_steps": [
            30,
            40
        ],
        "workers": 4,
        "lora_lr": 2e-05
    },
    "cmaf": {
        "n_heads": 4,
        "dropout": 0.5,
        "modalities": [
            {
                "name": "color",
                "data_type": "color",
                "optical_flow": false,
                "in_planes": 3,
                "backbone": "resnet",
                "n_classes": 25,
                "n_frames": 40,
                "n_head": 8,
                "ff_size": 1024,
                "n_module": 6,
                "dropout2d": 0.1,
                "dropout1d": 0.5,
                "use_tsm": true,
                "use_mspe": false,
                "modality_id": 0,
                "checkpoint": "experiments/BL2_tsm/NVGestures/checkpoints/NVGestures/best_tsm_nvgestures_color.pth",
                "lora": true,
                "lora_r": 4,
                "lora_alpha": 8,
                "lora_target": "layer4",
                "lora_fc": true
            },
            {
                "name": "depth",
                "data_type": "depth",
                "optical_flow": false,
                "in_planes": 1,
                "backbone": "resnet",
                "n_classes": 25,
                "n_frames": 40,
                "n_head": 8,
                "ff_size": 1024,
                "n_module": 6,
                "dropout2d": 0.1,
                "dropout1d": 0.5,
                "use_tsm": true,
                "use_mspe": false,
                "modality_id": 1,
                "checkpoint": "experiments/BL2_tsm/NVGestures/checkpoints/NVGestures/best_tsm_nvgestures_depth.pth",
                "lora": true,
                "lora_r": 4,
                "lora_alpha": 8,
                "lora_target": "layer4",
                "lora_fc": true
            },
            {
                "name": "ir",
                "data_type": "ir",
                "optical_flow": false,
                "in_planes": 1,
                "backbone": "resnet",
                "n_classes": 25,
                "n_frames": 40,
                "n_head": 8,
                "ff_size": 1024,
                "n_module": 6,
                "dropout2d": 0.1,
                "dropout1d": 0.5,
                "use_tsm": true,
                "use_mspe": false,
                "modality_id": 2,
                "checkpoint": "experiments/BL2_tsm/NVGestures/checkpoints/NVGestures/best_tsm_nvgestures_ir.pth",
                "lora": true,
                "lora_r": 4,
                "lora_alpha": 8,
                "lora_target": "layer4",
                "lora_fc": true
            },
            {
                "name": "normal",
                "data_type": "normal",
                "optical_flow": false,
                "in_planes": 3,
                "backbone": "resnet",
                "n_classes": 25,
                "n_frames": 40,
                "n_head": 8,
                "ff_size": 1024,
                "n_module": 6,
                "dropout2d": 0.1,
                "dropout1d": 0.5,
                "use_tsm": true,
                "use_mspe": false,
                "modality_id": 3,
                "checkpoint": "experiments/BL2_tsm/NVGestures/checkpoints/NVGestures/best_tsm_nvgestures_normal.pth",
                "lora": true,
                "lora_r": 4,
                "lora_alpha": 8,
                "lora_target": "layer4",
                "lora_fc": true
            },
            {
                "name": "optflow",
                "data_type": "depth",
                "optical_flow": true,
                "in_planes": 2,
                "backbone": "resnet",
                "n_classes": 25,
                "n_frames": 40,
                "n_head": 8,
                "ff_size": 1024,
                "n_module": 6,
                "dropout2d": 0.1,
                "dropout1d": 0.5,
                "use_tsm": true,
                "use_mspe": false,
                "modality_id": 4,
                "checkpoint": "experiments/BL2_tsm/NVGestures/checkpoints/NVGestures/best_tsm_nvgestures_optflow.pth",
                "lora": true,
                "lora_r": 4,
                "lora_alpha": 8,
                "lora_target": "layer4",
                "lora_fc": true
            }
        ],
        "n_bottleneck": 4,
        "n_layers": 1,
        "dff": 512,
        "init_fusion_logit": -20.0,
        "freeze_gate": true
    }
}