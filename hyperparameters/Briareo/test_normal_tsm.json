{
    "name": "Gesture Recognition",
    "dataset": "Briareo",
    "epochs": 100,
    "phase": "test",
    "data": {
        "optical_flow": false,
        "type": "normal",
        "n_classes": 12,
        "n_frames": 40,
        "data_path": "/data/Briareo",
        "result_dir": "./result",
        "batch_size": 8,
        "csv_dir": "./experiments/BL2_tsm/Briareo/csv/"
    },
    "checkpoints": {
        "save_policy": "best",
        "save_name": "tsm_briareo_normal",
        "save_dir": "./experiments/BL2_tsm/Briareo/checkpoints/",
        "save_iters": 30,
        "tb_path": "./experiments/BL2_tsm/Briareo/train_log"
    },
    "solver": {
        "type": "AdamW",
        "workers": 4,
        "weight_decay": 0.0001,
        "base_lr": 0.0001,
        "decay_steps": [
            50,
            75
        ]
    },
    "network": {
        "backbone": "resnet",
        "pretrained": true,
        "ff_size": 1024,
        "n_head": 8,
        "dropout2d": 0.1,
        "dropout1d": 0.5,
        "n_module": 6,
        "use_tsm": true
    },
    "resume": "experiments/BL2_tsm/Briareo/checkpoints/Briareo/best_tsm_briareo_normal.pth"
}